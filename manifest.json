{
  "manifest_version": 3,
  "name": "AnyMenu Helper",
  "version": "1.0",
  "description": "This extension is solely designed to enhance the content-aware functionality of the AnyMenu software in a browser environment.",
  "icons": {
    "48": "icons/border-48.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "any-menu@linczero",
      "strict_min_version": "109.0"
    }
  },

  "permissions": [
    "storage"
  ],

  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": false
  },

  "background": {
    "service_worker": "src/background/background.js",
    "scripts": ["src/background/background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/debug.js", "src/content/bridge.js", "src/content/main.js"]
    }
  ]
}
